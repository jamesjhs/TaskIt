# ===== Jobber Server Environment Variables =====

# JWT signing secret — MUST be changed before production deployment
JWT_SECRET=change-me-before-deploy

# Server port (default: 3000)
PORT=3000

# Optional: override the SQLite database file path
# DB_PATH=/path/to/custom/jobber.db

# Account lockout settings
# Number of consecutive failed logins before locking an account (default: 5)
MAX_LOGIN_ATTEMPTS=5
# How many minutes a locked account stays locked (default: 30)
LOCKOUT_MINUTES=30

# If set, the user registering with this email is automatically granted the admin role
# ADMIN_EMAIL=admin@example.com

# Optional: set the public-facing base URL used for invite/magic links
# Without this, the URL is derived from the request Host header (less secure in production)
# BASE_URL=https://jobber.example.com

# These seed the smtp_settings DB row on first run; afterwards manage via Admin UI
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Set to "true" to use TLS (port 465); leave blank/false for STARTTLS
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
# From address for outgoing mail (defaults to SMTP_USER if not set)
SMTP_FROM=Jobber <noreply@example.com>
