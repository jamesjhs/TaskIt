# ===== TaskIt! Server Environment Variables =====

# JWT signing secret — MUST be changed before production deployment
JWT_SECRET=change-me-before-deploy

# Server port (default: 3000)
PORT=3000

# Optional: override the SQLite database file path
# DB_PATH=/path/to/custom/taskit.db

# Database encryption key — enables SQLite3MultipleCiphers full-file encryption.
# Set to a strong random passphrase (e.g. 32+ chars) before first run, or leave
# unset to keep the database unencrypted.
#
# WARNING: If you add this key to an existing plaintext database the server will
# fail to start with a "file is not a database" error. You must migrate the data
# first by running the migration script:
#
#   node server/encrypt-db.js
#
# Then replace the original database file with the encrypted output and restart.
# See HOWTO.md for full details.
# DB_ENCRYPTION_KEY=change-me-to-a-strong-random-passphrase

# Account lockout settings
# Number of consecutive failed logins before locking an account (default: 5)
MAX_LOGIN_ATTEMPTS=5
# How many minutes a locked account stays locked (default: 30)
LOCKOUT_MINUTES=30

# If set, the user registering with this email is automatically granted the admin role
# ADMIN_EMAIL=admin@example.com

# Optional: set the public-facing base URL used for invite/magic links
# Without this, the URL is derived from the request Host header (less secure in production)
# BASE_URL=https://taskit.example.com

# These seed the smtp_settings DB row on first run; afterwards manage via Admin UI
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Set to "true" to use TLS (port 465); leave blank/false for STARTTLS
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
# From address for outgoing mail (defaults to SMTP_USER if not set)
SMTP_FROM=TaskIt! <noreply@example.com>
