{
  "name": "jobber-server",
  "version": "1.0.0",
  "description": "Jobber task management server",
  "main": "dist/index.js",
  "scripts": {
    "build:css": "tailwindcss -i src/css/input.css -o ../public/tailwind.css --minify",
    "build": "npm run build:css && tsc",
    "start": "node dist/index.js",
    "dev:css": "tailwindcss -i src/css/input.css -o ../public/tailwind.css --watch",
    "dev": "ts-node-dev --respawn src/index.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.5",
    "@types/uuid": "^9.0.8",
    "tailwindcss": "^3.4.19",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
