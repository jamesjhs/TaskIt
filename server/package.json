{
  "name": "jobber-server",
  "version": "1.0.7",
  "description": "Jobber task management server",
  "main": "dist/index.js",
  "scripts": {
    "build:css": "tailwindcss -i src/css/input.css -o ../public/tailwind.css --minify",
    "build": "npm run build:css && tsc",
    "start": "node dist/index.js",
    "dev:css": "tailwindcss -i src/css/input.css -o ../public/tailwind.css --watch",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^2.4.3",
    "better-sqlite3-multiple-ciphers": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^9.0.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
