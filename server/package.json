{
  "name": "taskit-server",
  "version": "1.21.3",
  "description": "TaskIt! task management server",
  "main": "dist/index.js",
  "scripts": {
    "build:css": "tailwindcss -i src/css/input.css -o ../public/tailwind.css --minify",
    "build": "npm run build:css && tsc",
    "start": "node dist/index.js",
    "dev:css": "tailwindcss -i src/css/input.css -o ../public/tailwind.css --watch",
    "dev": "tsx watch src/index.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^2.4.3",
    "better-sqlite3-multiple-ciphers": "^12.8.0",
    "dotenv": "^17.4.1",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
